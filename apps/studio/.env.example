# Copy to .env and fill in. Never commit .env.
#
# Must match SANITY_PREVIEW_SECRET on the web app — it is what /api/preview
# checks before enabling Draft Mode.
#
# This is intentionally NOT the revalidate secret: the Studio bundle is served
# publicly, so this value is readable by anyone who opens the Studio. Keep it
# separate so a leak cannot also trigger /api/revalidate.
SANITY_STUDIO_PREVIEW_SECRET=

# Base URL the "Open Preview" button points at.
# Defaults to https://newspotli.com. Set to http://localhost:3000 for local dev.
SANITY_STUDIO_SITE_URL=https://newspotli.com
